// ============================================================================
// Purchase Management — Spec 005 (enterprise procurement layer).
//
// This section EXTENDS the existing Spec-002 purchasing spine (suppliers,
// purchase_requisitions, purchase_orders, goods_receipts, purchase_returns,
// financial_notes) rather than replacing it. New capabilities land as pod_*
// tables: supplier CRM satellites, RFQ, supplier quotations, a generic approval
// engine, supplier invoices + 3-way match (AP subledger), landed cost, supplier
// payments, attachments, custom fields, and admin-customizable status/lookup
// tables.
//
// Conventions (match the rest of the schema): UUID PKs; tenant scoped via a real
// TenantAccount relation with cascade; cross-aggregate/lookup references are bare
// scalar @db.Uuid columns with app-enforced integrity (no @relation); header->line
// links use real relations with cascade. Statuses are stored as `statusCode`
// strings validated against pod_document_statuses / pod_status_transitions (the
// lookup-table analogue of the enum state machine used by the Spec-002 docs, which
// keep their native enums). Money: Decimal(19,4); unit cost/price: Decimal(19,6);
// quantity: Decimal(18,4); tax rate: Decimal(9,6); exchange rate: Decimal(19,8).
// company_id defaults to the tenant; branch_id is an optional operational unit
// (warehouse today) — both nullable for future multi-company/branch.
// ============================================================================

// --- Status & classification lookup tables (admin-customizable) --------------

model PodDocumentStatus {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String?        @map("tenant_id") @db.Uuid
  entityType String         @map("entity_type")
  code       String
  name       String
  sortOrder  Int            @default(0) @map("sort_order")
  isInitial  Boolean        @default(false) @map("is_initial")
  isTerminal Boolean        @default(false) @map("is_terminal")
  color      String?
  isActive   Boolean        @default(true) @map("is_active")
