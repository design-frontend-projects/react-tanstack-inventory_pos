  @@index([tenantId, noteType, status], map: "financial_notes_tenant_type_status_idx")
  @@index([tenantId, customerId], map: "financial_notes_tenant_customer_idx")
  @@index([tenantId, supplierId], map: "financial_notes_tenant_supplier_idx")
  @@map("financial_notes")
}

// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 8 reservations). A reservation is a soft
// hold: it raises the balance `reserved` bucket (never `on_hand`), so
// `available = on_hand − reserved − allocated` drops without any ledger movement.
// Confirming a sales order reserves its lines; fulfilment releases the hold and
// posts the SALE; cancel / expiry release it. The hold is adjusted only under the
// same `SELECT … FOR UPDATE` balance lock the movement engine uses.
// ============================================================================

model StockReservation {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  reservationType     ReservationType   @map("reservation_type")
  productId           String            @map("product_id") @db.Uuid
  variantId           String?           @map("variant_id") @db.Uuid
  warehouseId         String            @map("warehouse_id") @db.Uuid
  locationId          String            @map("location_id") @db.Uuid
  lotId               String?           @map("lot_id") @db.Uuid
  serialId            String?           @map("serial_id") @db.Uuid
  uomId               String            @map("uom_id") @db.Uuid
  quantity            Decimal           @db.Decimal(18, 4)
  fulfilledQty        Decimal           @default(0) @map("fulfilled_qty") @db.Decimal(18, 4)
  releasedQty         Decimal           @default(0) @map("released_qty") @db.Decimal(18, 4)
  status              ReservationStatus @default(ACTIVE)
  sourceDocType       SourceDocType?    @map("source_doc_type")
  sourceDocId         String?           @map("source_doc_id") @db.Uuid
  sourceDocLineId     String?           @map("source_doc_line_id") @db.Uuid
  sourceDocNumber     String?           @map("source_doc_number")
  expiresAt           DateTime?         @map("expires_at")
  reservedByProfileId String?           @map("reserved_by_profile_id") @db.Uuid
  notes               String?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  tenant              TenantAccount     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, status], map: "stock_reservations_tenant_status_idx")
  @@index([tenantId, sourceDocType, sourceDocId], map: "stock_reservations_source_idx")
  @@index([tenantId, sourceDocLineId], map: "stock_reservations_source_line_idx")
  @@index([tenantId, productId, warehouseId], map: "stock_reservations_product_wh_idx")
  @@index([tenantId, expiresAt], map: "stock_reservations_expiry_idx")
  @@map("stock_reservations")
}

// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 9 batch / serial / expiry). Lot and
// SerialNumber are masters keyed to a product; the on-hand quantity for a lot or
// serial lives in StockBalance (grained by lotId / serialId), not here. The
// movement engine enforces the product's trackingPolicy (LOT requires a lot,
// SERIAL requires a serial at qty 1) and stamps a serial's current
// location/status as it moves. Expiry sweeps flip lot status to EXPIRED (FEFO
// picks the nearest expiry first).
// ============================================================================

model Lot {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  productId       String         @map("product_id") @db.Uuid
  variantId       String?        @map("variant_id") @db.Uuid
  lotNumber       String         @map("lot_number")
  status          LotStatus      @default(ACTIVE)
  manufactureDate DateTime?      @map("manufacture_date")
  expiryDate      DateTime?      @map("expiry_date")
  receivedDate    DateTime?      @map("received_date")
  supplierId      String?        @map("supplier_id") @db.Uuid
  initialQty      Decimal        @default(0) @map("initial_qty") @db.Decimal(18, 4)
  sourceDocType   SourceDocType? @map("source_doc_type")
  sourceDocId     String?        @map("source_doc_id") @db.Uuid
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  tenant          TenantAccount  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, productId, lotNumber], map: "lots_tenant_product_number_unique")
  @@index([tenantId, productId, expiryDate], map: "lots_fefo_idx")
  @@index([tenantId, status], map: "lots_tenant_status_idx")
  @@index([tenantId, expiryDate], map: "lots_expiry_idx")
  @@map("lots")
}

model SerialNumber {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @map("tenant_id") @db.Uuid
  productId          String         @map("product_id") @db.Uuid
  variantId          String?        @map("variant_id") @db.Uuid
  serialNumber       String         @map("serial_number")
  status             SerialStatus   @default(IN_STOCK)
  currentWarehouseId String?        @map("current_warehouse_id") @db.Uuid
  currentLocationId  String?        @map("current_location_id") @db.Uuid
  lotId              String?        @map("lot_id") @db.Uuid
  supplierId         String?        @map("supplier_id") @db.Uuid
  warrantyExpiresAt  DateTime?      @map("warranty_expires_at")
  sourceDocType      SourceDocType? @map("source_doc_type")
  sourceDocId        String?        @map("source_doc_id") @db.Uuid
  soldAt             DateTime?      @map("sold_at")
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  tenant             TenantAccount  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, productId, serialNumber], map: "serials_tenant_product_number_unique")
  @@index([tenantId, status], map: "serials_tenant_status_idx")
  @@index([tenantId, currentLocationId], map: "serials_location_idx")
  @@index([tenantId, lotId], map: "serials_lot_idx")
  @@map("serial_numbers")
}

// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 10 manufacturing). A BillOfMaterials
// defines the recipe (components per output batch). A ProductionOrder consumes
// its materials (PRODUCTION_CONSUMPTION OUT at WAC) and receives finished goods
// (PRODUCTION_OUTPUT IN); the finished-good unit cost rolls up from consumed
// material cost + overhead / produced quantity, then flows into the finished
// product's weighted average through the engine like any other receipt.
// ============================================================================

model BillOfMaterials {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  productId    String         @map("product_id") @db.Uuid
  variantId    String?        @map("variant_id") @db.Uuid
  name         String
  version      Int            @default(1)
  status       BomStatus      @default(ACTIVE)
  isDefault    Boolean        @default(false) @map("is_default")
  outputQty    Decimal        @default(1) @map("output_qty") @db.Decimal(18, 4)
  uomId        String         @map("uom_id") @db.Uuid
  overheadCost Decimal        @default(0) @map("overhead_cost") @db.Decimal(19, 4)
  notes        String?
  deletedAt    DateTime?      @map("deleted_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  tenant       TenantAccount  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  components   BomComponent[]

  @@index([tenantId, productId], map: "boms_tenant_product_idx")
  @@index([tenantId, status], map: "boms_tenant_status_idx")
  @@map("bills_of_materials")
}

model BomComponent {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  bomId              String          @map("bom_id") @db.Uuid
  lineNo             Int             @map("line_no")
  componentProductId String          @map("component_product_id") @db.Uuid
  componentVariantId String?         @map("component_variant_id") @db.Uuid
  quantity           Decimal         @db.Decimal(18, 4)
  uomId              String          @map("uom_id") @db.Uuid
  scrapPercent       Decimal         @default(0) @map("scrap_percent") @db.Decimal(9, 6)
  notes              String?
  createdAt          DateTime        @default(now()) @map("created_at")
  tenant             TenantAccount   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bom                BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, bomId], map: "bom_components_bom_idx")
  @@index([tenantId, componentProductId], map: "bom_components_product_idx")
  @@map("bom_components")
}

model ProductionOrder {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @map("tenant_id") @db.Uuid
  documentNumber   String                @map("document_number")
  productId        String                @map("product_id") @db.Uuid
  variantId        String?               @map("variant_id") @db.Uuid
  bomId            String?               @map("bom_id") @db.Uuid
  warehouseId      String                @map("warehouse_id") @db.Uuid
  outputLocationId String                @map("output_location_id") @db.Uuid
  status           ProductionOrderStatus @default(DRAFT)
  plannedQty       Decimal               @map("planned_qty") @db.Decimal(18, 4)
  producedQty      Decimal               @default(0) @map("produced_qty") @db.Decimal(18, 4)
  materialCost     Decimal               @default(0) @map("material_cost") @db.Decimal(19, 4)
  overheadCost     Decimal               @default(0) @map("overhead_cost") @db.Decimal(19, 4)
  outputCost       Decimal               @default(0) @map("output_cost") @db.Decimal(19, 4)
  plannedStartDate DateTime?             @map("planned_start_date")
  plannedEndDate   DateTime?             @map("planned_end_date")
  notes            String?
  createdByProfileId String?             @map("created_by_profile_id") @db.Uuid
  correlationId    String?               @map("correlation_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  tenant           TenantAccount         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  materials        ProductionMaterial[]
  outputs          ProductionOutput[]

  @@unique([tenantId, documentNumber], map: "production_orders_tenant_number_unique")
  @@index([tenantId, status], map: "production_orders_tenant_status_idx")
  @@index([tenantId, productId], map: "production_orders_tenant_product_idx")
  @@map("production_orders")
}

model ProductionMaterial {
  id                 String          @id @default(uuid()) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  productionOrderId  String          @map("production_order_id") @db.Uuid
  lineNo             Int             @map("line_no")
  componentProductId String          @map("component_product_id") @db.Uuid
  componentVariantId String?         @map("component_variant_id") @db.Uuid
  fromLocationId     String          @map("from_location_id") @db.Uuid
  uomId              String          @map("uom_id") @db.Uuid
  plannedQty         Decimal         @map("planned_qty") @db.Decimal(18, 4)
  consumedQty        Decimal         @default(0) @map("consumed_qty") @db.Decimal(18, 4)
  unitCost           Decimal?        @map("unit_cost") @db.Decimal(19, 6)
  lotId              String?         @map("lot_id") @db.Uuid
  serialId           String?         @map("serial_id") @db.Uuid
  isConsumed         Boolean         @default(false) @map("is_consumed")
  createdAt          DateTime        @default(now()) @map("created_at")
  tenant             TenantAccount   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productionOrder    ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, productionOrderId], map: "production_materials_order_idx")
  @@index([tenantId, componentProductId], map: "production_materials_product_idx")
  @@map("production_materials")
}

model ProductionOutput {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  productionOrderId String          @map("production_order_id") @db.Uuid
  lineNo            Int             @map("line_no")
  productId         String          @map("product_id") @db.Uuid
  variantId         String?         @map("variant_id") @db.Uuid
  toLocationId      String          @map("to_location_id") @db.Uuid
  uomId             String          @map("uom_id") @db.Uuid
  quantity          Decimal         @db.Decimal(18, 4)
  unitCost          Decimal         @map("unit_cost") @db.Decimal(19, 6)
  lotId             String?         @map("lot_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")
  tenant            TenantAccount   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, productionOrderId], map: "production_outputs_order_idx")
  @@map("production_outputs")
}

// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 11 reorder + valuation). ReorderRule is
// the per-product×warehouse override of the product-level reorder defaults; the
// reorder-suggestion query compares live available stock to the reorder point.
// StockSnapshot captures a point-in-time valuation per period (monthly job) so
// historical valuation does not require replaying the whole movement ledger.
// ============================================================================

model ReorderRule {
  id                  String        @id @default(uuid()) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  productId           String        @map("product_id") @db.Uuid
  variantId           String?       @map("variant_id") @db.Uuid
  warehouseId         String        @map("warehouse_id") @db.Uuid
  minStock            Decimal       @default(0) @map("min_stock") @db.Decimal(18, 4)
  maxStock            Decimal       @default(0) @map("max_stock") @db.Decimal(18, 4)
  safetyStock         Decimal       @default(0) @map("safety_stock") @db.Decimal(18, 4)
  reorderPoint        Decimal       @default(0) @map("reorder_point") @db.Decimal(18, 4)
  reorderQty          Decimal       @default(0) @map("reorder_qty") @db.Decimal(18, 4)
  economicOrderQty    Decimal?      @map("economic_order_qty") @db.Decimal(18, 4)
  leadTimeDays        Int?          @map("lead_time_days")
  preferredSupplierId String?       @map("preferred_supplier_id") @db.Uuid
  isActive            Boolean       @default(true) @map("is_active")
  notes               String?
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  tenant              TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, productId, warehouseId], map: "reorder_rules_tenant_product_wh_unique")
  @@index([tenantId, warehouseId], map: "reorder_rules_tenant_wh_idx")
  @@index([tenantId, productId], map: "reorder_rules_tenant_product_idx")
  @@map("reorder_rules")
}

model StockSnapshot {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  periodKey    String        @map("period_key")
  snapshotDate DateTime      @default(now()) @map("snapshot_date")
  productId    String        @map("product_id") @db.Uuid
  variantId    String?       @map("variant_id") @db.Uuid
  warehouseId  String?       @map("warehouse_id") @db.Uuid
  onHand       Decimal       @default(0) @map("on_hand") @db.Decimal(18, 4)
  reserved     Decimal       @default(0) @db.Decimal(18, 4)
  allocated    Decimal       @default(0) @db.Decimal(18, 4)
  avgUnitCost  Decimal       @default(0) @map("avg_unit_cost") @db.Decimal(19, 6)
  totalValue   Decimal       @default(0) @map("total_value") @db.Decimal(19, 4)
  createdAt    DateTime      @default(now()) @map("created_at")
  tenant       TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, periodKey], map: "stock_snapshots_tenant_period_idx")
  @@index([tenantId, productId], map: "stock_snapshots_tenant_product_idx")
  @@map("stock_snapshots")
}

// ============================================================================
// Enterprise CRM — Spec 003 (Phase 0 event infrastructure). DomainEvent is the
// module-neutral transactional outbox: source services append a typed event row
// in the SAME transaction as the business write, so an event exists iff the
// business change committed. Consumers (currently only the CRM projector) read
// forward over the bigserial `id` with a per-consumer cursor; delivery is
// at-least-once and every projection is idempotent (unique sourceEventId /
// monotonic sequence guards). `eventType` is a string validated by the TS
// catalog in src/server/events/domain-event-types.ts — new event types must not
// require a migration. Payload Decimals are serialized as strings.
// CrmProjectionCursor is global consumer state (one row per consumer, no
// tenantId — the cursor advances over the cross-tenant sequence).
// ============================================================================

model DomainEvent {
  id             BigInt        @id @default(autoincrement())
  eventId        String        @unique(map: "domain_events_event_id_unique") @default(uuid()) @map("event_id") @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  eventType      String        @map("event_type")
  aggregateType  String        @map("aggregate_type")
  aggregateId    String        @map("aggregate_id") @db.Uuid
  customerId     String?       @map("customer_id") @db.Uuid
  payloadJson    Json          @map("payload_json")
  correlationId  String?       @map("correlation_id") @db.Uuid
  actorProfileId String?       @map("actor_profile_id") @db.Uuid
  occurredAt     DateTime      @default(now()) @map("occurred_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  tenant         TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, customerId], map: "domain_events_tenant_customer_idx")
  @@index([eventType], map: "domain_events_type_idx")
  @@map("domain_events")
}

model CrmProjectionCursor {
  id           String   @id @default(uuid()) @db.Uuid
  consumerName String   @unique(map: "crm_projection_cursors_consumer_unique") @map("consumer_name")
  lastSequence BigInt   @default(0) @map("last_sequence")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("crm_projection_cursors")
}

// ============================================================================
// Enterprise CRM — Spec 003 (Phase 1 customer management). The existing
// `customers` table stays the master; every CRM table is a satellite keyed by a
// bare `customerId` scalar (app-enforced integrity, same as sales documents).
// The 1:1 CrmCustomerProfile carries identity/preference attributes only — all
// computed values live in the intelligence tables (crm_customer_metrics,
// crm_loyalty_accounts, crm_customer_scores). Consents are current-state rows;
// their history is the timeline (every change emits crm.consent_changed).
// ============================================================================

enum CrmLifecycleStatus {
  PROSPECT @map("prospect")
  ACTIVE   @map("active")
  AT_RISK  @map("at_risk")
  INACTIVE @map("inactive")
  BLOCKED  @map("blocked")

  @@map("CrmLifecycleStatus")
}

enum CrmContactType {
  PHONE  @map("phone")
  EMAIL  @map("email")
  SOCIAL @map("social")
  OTHER  @map("other")

  @@map("CrmContactType")
}

enum CrmAddressType {
  BILLING  @map("billing")
  SHIPPING @map("shipping")
  DELIVERY @map("delivery")
  OTHER    @map("other")

  @@map("CrmAddressType")
}

enum CrmRelationType {
  FAMILY          @map("family")
  EMERGENCY       @map("emergency")
  COMPANY_CONTACT @map("company_contact")
  REFERRER        @map("referrer")
  OTHER           @map("other")

  @@map("CrmRelationType")
}

enum ConsentChannel {
  EMAIL    @map("email")
  SMS      @map("sms")
  PUSH     @map("push")
  WHATSAPP @map("whatsapp")
  PHONE    @map("phone")

  @@map("ConsentChannel")
}

enum ConsentPurpose {
  MARKETING     @map("marketing")
  TRANSACTIONAL @map("transactional")
  SURVEY        @map("survey")

  @@map("ConsentPurpose")
}

enum ConsentStatus {
  GRANTED   @map("granted")
  DENIED    @map("denied")
  WITHDRAWN @map("withdrawn")

  @@map("ConsentStatus")
}

enum CrmFieldType {
  TEXT         @map("text")
  NUMBER       @map("number")
  DATE         @map("date")
  BOOLEAN      @map("boolean")
  SELECT       @map("select")
  MULTI_SELECT @map("multi_select")

  @@map("CrmFieldType")
}

model CrmCustomerProfile {
  id                 String             @id @default(uuid()) @db.Uuid
  tenantId           String             @map("tenant_id") @db.Uuid
  customerId         String             @map("customer_id") @db.Uuid
  dateOfBirth        DateTime?          @map("date_of_birth") @db.Date
  anniversaryDate    DateTime?          @map("anniversary_date") @db.Date
  gender             String?
  languageCode       String?            @map("language_code")
  currencyCode       String?            @map("currency_code")
  timezone           String?
  lifecycleStatus    CrmLifecycleStatus @default(PROSPECT) @map("lifecycle_status")
  vipLevel           Int                @default(0) @map("vip_level")
  classification     String?
  isCorporate        Boolean            @default(false) @map("is_corporate")
  companyName        String?            @map("company_name")
  acquisitionChannel String?            @map("acquisition_channel")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  tenant             TenantAccount      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, customerId], map: "crm_customer_profiles_tenant_customer_unique")
  @@index([tenantId, lifecycleStatus], map: "crm_customer_profiles_lifecycle_idx")
  @@map("crm_customer_profiles")
}

model CrmCustomerContact {
