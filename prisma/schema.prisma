}

// ============================================================================
// Enterprise CRM — Spec 003 (Phase 2 timeline). Append-only chronological feed
// per customer, written by the projector from domain events (sourceEventId is
// the idempotency key — replaying an event is a no-op) plus manual notes
// (sourceEventId null, createdByProfileId set). summaryJson is a small display
// payload; refType/refId deep-link to the owning aggregate. Never the source of
// truth for anything — safe to rebuild from the outbox.
// ============================================================================

model CrmTimelineEntry {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  customerId         String        @map("customer_id") @db.Uuid
  entryType          String        @map("entry_type")
  title              String
  summaryJson        Json?         @map("summary_json")
  refType            String?       @map("ref_type")
  refId              String?       @map("ref_id") @db.Uuid
  sourceEventId      String?       @unique(map: "crm_timeline_entries_source_event_unique") @map("source_event_id") @db.Uuid
  occurredAt         DateTime      @map("occurred_at")
  createdByProfileId String?       @map("created_by_profile_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at")
  tenant             TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, customerId, occurredAt(sort: Desc)], map: "crm_timeline_tenant_customer_time_idx")
  @@map("crm_timeline_entries")
}

// ============================================================================
// Enterprise CRM — Spec 003 (Phase 3 loyalty). The ledger is the source of
// truth: every balance change appends a signed CrmLoyaltyLedgerEntry and
// mutates CrmLoyaltyAccount.pointsBalance in the SAME transaction under a row
// lock (invariant: sum(ledger.points) == account.pointsBalance). Redemption is
// synchronous (a customer cannot spend the same points twice); earning is
// folded from domain events by the projector, deduplicated by the unique
// sourceEventId. EARN/BONUS rows are FIFO expiry lots: remainingPoints tracks
// what redemption/expiry has not yet consumed. Customer.loyaltyPoints is a
// DEPRECATED read cache mirrored from the account by the projector.
// ============================================================================

enum LoyaltyEntryType {
  EARN     @map("earn")
  REDEEM   @map("redeem")
  ADJUST   @map("adjust")
  EXPIRE   @map("expire")
  BONUS    @map("bonus")
  REVERSAL @map("reversal")

  @@map("LoyaltyEntryType")
}

enum LoyaltyRuleType {
  BASE           @map("base")
  CATEGORY_BONUS @map("category_bonus")
  PRODUCT_BONUS  @map("product_bonus")
  BIRTHDAY       @map("birthday")
  ANNIVERSARY    @map("anniversary")
  CHANNEL        @map("channel")

  @@map("LoyaltyRuleType")
}

