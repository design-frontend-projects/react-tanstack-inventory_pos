// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 7 returns + credit/debit notes).
// A SalesReturn receipt POSTS a SALES_RETURN (IN) movement per restockable line,
// re-entering stock at the original costAtSale (captured on the origin sale line)
// so returned goods do not leak margin into the weighted-average cost. POS refunds
// drive a SalesReturn sourced from the completed sale. FinancialNote models the
// AR credit note (from a sales return) and the AP debit note (from a purchase
// return) as a single financial document with no inventory effect.
// ============================================================================

model SalesReturn {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  documentNumber     String            @map("document_number")
  customerId         String?           @map("customer_id") @db.Uuid
  warehouseId        String            @map("warehouse_id") @db.Uuid
  originType         SourceDocType?    @map("origin_type")
  salesOrderId       String?           @map("sales_order_id") @db.Uuid
  posSaleId          String?           @map("pos_sale_id") @db.Uuid
  status             SalesReturnStatus @default(DRAFT)
  reason             SalesReturnReason @default(OTHER)
  returnDate         DateTime          @default(now()) @map("return_date")
  currencyCode       String            @default("USD") @map("currency_code")
  subtotal           Decimal           @default(0) @db.Decimal(19, 4)
  discountTotal      Decimal           @default(0) @map("discount_total") @db.Decimal(19, 4)
  taxTotal           Decimal           @default(0) @map("tax_total") @db.Decimal(19, 4)
  grandTotal         Decimal           @default(0) @map("grand_total") @db.Decimal(19, 4)
  restockValue       Decimal           @default(0) @map("restock_value") @db.Decimal(19, 4)
  refundMethod       PaymentMethod?    @map("refund_method")
  notes              String?
  isPosted           Boolean           @default(false) @map("is_posted")
  postedAt           DateTime?         @map("posted_at")
  postedByProfileId  String?           @map("posted_by_profile_id") @db.Uuid
  createdByProfileId String?           @map("created_by_profile_id") @db.Uuid
  correlationId      String?           @map("correlation_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  tenant             TenantAccount     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lines              SalesReturnLine[]

  @@unique([tenantId, documentNumber], map: "sales_returns_tenant_number_unique")
  @@index([tenantId, status], map: "sales_returns_tenant_status_idx")
  @@index([tenantId, customerId], map: "sales_returns_tenant_customer_idx")
  @@index([tenantId, posSaleId], map: "sales_returns_tenant_pos_sale_idx")
  @@map("sales_returns")
}

model SalesReturnLine {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  salesReturnId String        @map("sales_return_id") @db.Uuid
  lineNo        Int           @map("line_no")
  productId     String        @map("product_id") @db.Uuid
  variantId     String?       @map("variant_id") @db.Uuid
  locationId    String        @map("location_id") @db.Uuid
  uomId         String        @map("uom_id") @db.Uuid
  quantity      Decimal       @db.Decimal(18, 4)
  unitPrice     Decimal       @map("unit_price") @db.Decimal(19, 4)
  discount      Decimal       @default(0) @db.Decimal(19, 4)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(19, 4)
  lineTotal     Decimal       @map("line_total") @db.Decimal(19, 4)
  costAtReturn  Decimal?      @map("cost_at_return") @db.Decimal(19, 6)
  restock       Boolean       @default(true)
  originLineId  String?       @map("origin_line_id") @db.Uuid
  lotId         String?       @map("lot_id") @db.Uuid
  serialId      String?       @map("serial_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  tenant        TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  salesReturn   SalesReturn   @relation(fields: [salesReturnId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, salesReturnId], map: "sales_return_lines_return_idx")
  @@index([tenantId, productId], map: "sales_return_lines_product_idx")
  @@map("sales_return_lines")
}

model FinancialNote {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  documentNumber     String        @map("document_number")
  noteType           NoteType      @map("note_type")
  status             NoteStatus    @default(DRAFT)
  customerId         String?       @map("customer_id") @db.Uuid
  supplierId         String?       @map("supplier_id") @db.Uuid
