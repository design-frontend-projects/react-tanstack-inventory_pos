  remainingQty    Decimal?      @map("remaining_qty") @db.Decimal(18, 4)
  createdAt       DateTime      @default(now()) @map("created_at")
  tenant          TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, purchaseOrderId], map: "purchase_order_lines_po_idx")
  @@index([tenantId, productId], map: "purchase_order_lines_product_idx")
