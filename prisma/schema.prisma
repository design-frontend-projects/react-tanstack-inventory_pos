// ============================================================================
// Enterprise CRM — Spec 003 (Phase 5 segmentation). A segment is a declarative
// rule (ruleJson: a tree of and/or over comparison conditions on the flat
// CustomerFacts projection). Membership is materialized in CrmSegmentMember and
// kept current by the segment projection: after each event folds into metrics,
// the affected customer is re-evaluated and enter/exit transitions emit
// crm.segment_entered/.exited events (which flow to the timeline). memberCount
// is a cache; a full rebuild recomputes it.
// ============================================================================

model CrmSegment {
  id            String             @id @default(uuid()) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  code          String
  name          String
  description   String?
  ruleJson      Json               @map("rule_json")
  isSystem      Boolean            @default(false) @map("is_system")
  isActive      Boolean            @default(true) @map("is_active")
  memberCount   Int                @default(0) @map("member_count")
  lastRebuiltAt DateTime?          @map("last_rebuilt_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")
  tenant        TenantAccount      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  members       CrmSegmentMember[]

  @@unique([tenantId, code], map: "crm_segments_tenant_code_unique")
  @@index([tenantId, isActive], map: "crm_segments_tenant_active_idx")
  @@map("crm_segments")
}

model CrmSegmentMember {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  segmentId  String        @map("segment_id") @db.Uuid
  customerId String        @map("customer_id") @db.Uuid
  addedAt    DateTime      @default(now()) @map("added_at")
  tenant     TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  segment    CrmSegment    @relation(fields: [segmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, segmentId, customerId], map: "crm_segment_members_tenant_segment_customer_unique")
  @@index([tenantId, customerId], map: "crm_segment_members_tenant_customer_idx")
  @@map("crm_segment_members")
}

// ============================================================================
// Enterprise CRM — Spec 003 (Phase 6 AI-ready scores). Model-agnostic
// prediction store: one row per (tenant, customer, scoreType). Producers upsert
// (`score` for scalar risk, `payloadJson` for ranked recommendations); model
// metadata + featuresJson snapshot make predictions auditable/reproducible.
// The Phase 4 churn heuristic writes scoreType='churn', modelName='heuristic-v1'
// as the proof-of-contract; future ML pipelines write the same shape without a
// migration.
// ============================================================================

model CrmCustomerScore {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  customerId   String        @map("customer_id") @db.Uuid
  scoreType    String        @map("score_type")
  score        Decimal?      @db.Decimal(9, 6)
  payloadJson  Json?         @map("payload_json")
  modelName    String        @map("model_name")
  modelVersion String        @map("model_version")
  featuresJson Json?         @map("features_json")
  computedAt   DateTime      @default(now()) @map("computed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  tenant       TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, customerId, scoreType], map: "crm_customer_scores_tenant_customer_type_unique")
  @@index([tenantId, scoreType, score(sort: Desc)], map: "crm_customer_scores_tenant_type_score_idx")
  @@map("crm_customer_scores")
}

