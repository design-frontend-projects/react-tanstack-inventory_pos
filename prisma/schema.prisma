// --- Landed cost -------------------------------------------------------------

model PodLandedCostVoucher {
  id                String                     @id @default(uuid()) @db.Uuid
  tenantId          String                     @map("tenant_id") @db.Uuid
  companyId         String?                    @map("company_id") @db.Uuid
  branchId          String?                    @map("branch_id") @db.Uuid
  documentNumber    String                     @map("document_number")
  statusCode        String                     @default("draft") @map("status_code")
  goodsReceiptId    String?                    @map("goods_receipt_id") @db.Uuid
  purchaseOrderId   String?                    @map("purchase_order_id") @db.Uuid
  supplierInvoiceId String?                    @map("supplier_invoice_id") @db.Uuid
  allocationBasis   String                     @default("value") @map("allocation_basis")
  currencyCode      String                     @default("USD") @map("currency_code")
  exchangeRate      Decimal                    @default(1) @map("exchange_rate") @db.Decimal(19, 8)
  totalCharges      Decimal                    @default(0) @map("total_charges") @db.Decimal(19, 4)
  notes             String?
  isPosted          Boolean                    @default(false) @map("is_posted")
  postedAt          DateTime?                  @map("posted_at")
  postedByProfileId String?                    @map("posted_by_profile_id") @db.Uuid
  correlationId     String?                    @map("correlation_id") @db.Uuid
  isActive          Boolean                    @default(true) @map("is_active")
  versionNumber     Int                        @default(1) @map("version_number")
  createdBy         String?                    @map("created_by") @db.Uuid
  updatedBy         String?                    @map("updated_by") @db.Uuid
  deletedBy         String?                    @map("deleted_by") @db.Uuid
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  deletedAt         DateTime?                  @map("deleted_at")
  tenant            TenantAccount              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  charges           PodLandedCostCharge[]
  allocations       PodLandedCostAllocation[]

  @@unique([tenantId, documentNumber], map: "pod_landed_cost_vouchers_tenant_number_unique")
  @@index([tenantId, statusCode], map: "pod_landed_cost_vouchers_tenant_status_idx")
  @@index([tenantId, goodsReceiptId], map: "pod_landed_cost_vouchers_grn_idx")
  @@map("pod_landed_cost_vouchers")
}

model PodLandedCostCharge {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  voucherId   String               @map("voucher_id") @db.Uuid
  lineNo      Int                  @map("line_no")
  costTypeId  String?              @map("cost_type_id") @db.Uuid
  description String?
  amount      Decimal              @db.Decimal(19, 4)
  supplierId  String?              @map("supplier_id") @db.Uuid
  taxAmount   Decimal              @default(0) @map("tax_amount") @db.Decimal(19, 4)
  createdAt   DateTime             @default(now()) @map("created_at")
  tenant      TenantAccount        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  voucher     PodLandedCostVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, voucherId], map: "pod_landed_cost_charges_voucher_idx")
  @@map("pod_landed_cost_charges")
}

model PodLandedCostAllocation {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  voucherId          String               @map("voucher_id") @db.Uuid
  goodsReceiptLineId String?              @map("goods_receipt_line_id") @db.Uuid
  purchaseOrderLineId String?             @map("purchase_order_line_id") @db.Uuid
  productId          String?              @map("product_id") @db.Uuid
  basisValue         Decimal              @default(0) @map("basis_value") @db.Decimal(19, 4)
  allocatedAmount    Decimal              @default(0) @map("allocated_amount") @db.Decimal(19, 4)
  createdAt          DateTime             @default(now()) @map("created_at")
  tenant             TenantAccount        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  voucher            PodLandedCostVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, voucherId], map: "pod_landed_cost_allocations_voucher_idx")
  @@map("pod_landed_cost_allocations")
}

// --- Supplier payments (AP) --------------------------------------------------

model PodSupplierPayment {
  id                String                         @id @default(uuid()) @db.Uuid
  tenantId          String                         @map("tenant_id") @db.Uuid
  companyId         String?                        @map("company_id") @db.Uuid
  branchId          String?                        @map("branch_id") @db.Uuid
  documentNumber    String                         @map("document_number")
  supplierId        String                         @map("supplier_id") @db.Uuid
  statusCode        String                         @default("draft") @map("status_code")
  paymentMethodId   String?                        @map("payment_method_id") @db.Uuid
  paymentDate       DateTime                       @default(now()) @map("payment_date")
  currencyCode      String                         @default("USD") @map("currency_code")
  exchangeRate      Decimal                        @default(1) @map("exchange_rate") @db.Decimal(19, 8)
  amount            Decimal                        @db.Decimal(19, 4)
  allocatedAmount   Decimal                        @default(0) @map("allocated_amount") @db.Decimal(19, 4)
  unallocatedAmount Decimal                        @default(0) @map("unallocated_amount") @db.Decimal(19, 4)
  referenceNumber   String?                        @map("reference_number")
  bankAccountId     String?                        @map("bank_account_id") @db.Uuid
  isAdvance         Boolean                        @default(false) @map("is_advance")
  notes             String?
  isPosted          Boolean                        @default(false) @map("is_posted")
  postedAt          DateTime?                      @map("posted_at")
  postedByProfileId String?                        @map("posted_by_profile_id") @db.Uuid
  correlationId     String?                        @map("correlation_id") @db.Uuid
  isActive          Boolean                        @default(true) @map("is_active")
  versionNumber     Int                            @default(1) @map("version_number")
  createdBy         String?                        @map("created_by") @db.Uuid
  updatedBy         String?                        @map("updated_by") @db.Uuid
  deletedBy         String?                        @map("deleted_by") @db.Uuid
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")
  deletedAt         DateTime?                      @map("deleted_at")
  tenant            TenantAccount                  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  allocations       PodSupplierPaymentAllocation[]

  @@unique([tenantId, documentNumber], map: "pod_supplier_payments_tenant_number_unique")
  @@index([tenantId, supplierId], map: "pod_supplier_payments_tenant_supplier_idx")
  @@index([tenantId, statusCode], map: "pod_supplier_payments_tenant_status_idx")
  @@map("pod_supplier_payments")
}

model PodSupplierPaymentAllocation {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  paymentId         String             @map("payment_id") @db.Uuid
  supplierInvoiceId String?            @map("supplier_invoice_id") @db.Uuid
  financialNoteId   String?            @map("financial_note_id") @db.Uuid
  allocatedAmount   Decimal            @default(0) @map("allocated_amount") @db.Decimal(19, 4)
  createdAt         DateTime           @default(now()) @map("created_at")
  tenant            TenantAccount      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  payment           PodSupplierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, paymentId], map: "pod_supplier_payment_allocations_payment_idx")
  @@index([tenantId, supplierInvoiceId], map: "pod_supplier_payment_allocations_invoice_idx")
  @@map("pod_supplier_payment_allocations")
}

// --- Cross-cutting: attachments & custom fields (polymorphic) ----------------

model PodAttachment {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  entityType         String        @map("entity_type")
  entityId           String        @map("entity_id") @db.Uuid
  fileName           String        @map("file_name")
  fileUrl            String        @map("file_url")
  mimeType           String?       @map("mime_type")
  fileSize           Int?          @map("file_size")
  category           String?
  uploadedByProfileId String?      @map("uploaded_by_profile_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")
  tenant             TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, entityType, entityId], map: "pod_attachments_entity_idx")
  @@map("pod_attachments")
}

model PodCustomFieldDefinition {
  id           String                @id @default(uuid()) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  entityType   String                @map("entity_type")
  fieldKey     String                @map("field_key")
  label        String
  fieldType    String                @map("field_type")
  optionsJson  Json?                 @map("options_json")
  isRequired   Boolean               @default(false) @map("is_required")
  displayOrder Int                   @default(0) @map("display_order")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  deletedAt    DateTime?             @map("deleted_at")
  tenant       TenantAccount         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  values       PodCustomFieldValue[]

  @@unique([tenantId, entityType, fieldKey], map: "pod_custom_field_definitions_scope_unique")
  @@map("pod_custom_field_definitions")
}

model PodCustomFieldValue {
  id           String                   @id @default(uuid()) @db.Uuid
  tenantId     String                   @map("tenant_id") @db.Uuid
  definitionId String                   @map("definition_id") @db.Uuid
  entityType   String                   @map("entity_type")
  entityId     String                   @map("entity_id") @db.Uuid
  valueJson    Json                     @map("value_json")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  tenant       TenantAccount            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  definition   PodCustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, definitionId, entityId], map: "pod_custom_field_values_grain_unique")
  @@index([tenantId, entityType, entityId], map: "pod_custom_field_values_entity_idx")
  @@map("pod_custom_field_values")
}
