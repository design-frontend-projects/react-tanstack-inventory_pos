  @@index([planId], map: "owner_tenant_subscriptions_plan_idx")
  @@map("owner_tenant_subscriptions")
}

// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 4 transfers + Phase 5 purchasing).
// Documents own their lifecycle (status enums + state-machine.ts guard) and POST
// movements through the engine: transfer ship/receive => TRANSFER_OUT/IN,
// goods receipt => PURCHASE_RECEIPT, purchase return => PURCHASE_RETURN.
// ============================================================================

enum TransferStatus {
  DRAFT              @map("draft")
  CONFIRMED          @map("confirmed")
  SHIPPED            @map("shipped")
  IN_TRANSIT         @map("in_transit")
  PARTIALLY_RECEIVED @map("partially_received")
  RECEIVED           @map("received")
  CLOSED             @map("closed")
  CANCELLED          @map("cancelled")

  @@map("TransferStatus")
}

enum RequisitionStatus {
  DRAFT     @map("draft")
  SUBMITTED @map("submitted")
  APPROVED  @map("approved")
  CONVERTED @map("converted")
  CLOSED    @map("closed")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("RequisitionStatus")
}

enum PurchaseOrderStatus {
  DRAFT              @map("draft")
  PENDING_APPROVAL   @map("pending_approval")
  APPROVED           @map("approved")
  CONFIRMED          @map("confirmed")
  PARTIALLY_RECEIVED @map("partially_received")
  RECEIVED           @map("received")
  CLOSED             @map("closed")
  CANCELLED          @map("cancelled")
  REJECTED           @map("rejected")

  @@map("PurchaseOrderStatus")
}

enum ReceiptStatus {
  DRAFT         @map("draft")
  RECEIVED      @map("received")
  QUALITY_CHECK @map("quality_check")
  PUT_AWAY      @map("put_away")
  COMPLETED     @map("completed")
  REJECTED      @map("rejected")

  @@map("ReceiptStatus")
}

enum PurchaseReturnStatus {
  DRAFT     @map("draft")
  REQUESTED @map("requested")
  APPROVED  @map("approved")
  SHIPPED   @map("shipped")
  RECEIVED  @map("received")
  REFUNDED  @map("refunded")
  CLOSED    @map("closed")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("PurchaseReturnStatus")
}

// --- Phase 4: stock transfers -----------------------------------------------

model StockTransfer {
  id                  String              @id @default(uuid()) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  documentNumber      String              @map("document_number")
  fromWarehouseId     String              @map("from_warehouse_id") @db.Uuid
  toWarehouseId       String              @map("to_warehouse_id") @db.Uuid
  status              TransferStatus      @default(DRAFT)
  notes               String?
  shipDate            DateTime?           @map("ship_date")
  receiveDate         DateTime?           @map("receive_date")
  shippedByProfileId  String?             @map("shipped_by_profile_id") @db.Uuid
  receivedByProfileId String?             @map("received_by_profile_id") @db.Uuid
  createdByProfileId  String?             @map("created_by_profile_id") @db.Uuid
  correlationId       String?             @map("correlation_id") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  tenant              TenantAccount       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lines               StockTransferLine[]

  @@unique([tenantId, documentNumber], map: "stock_transfers_tenant_number_unique")
  @@index([tenantId, status], map: "stock_transfers_tenant_status_idx")
  @@map("stock_transfers")
}

model StockTransferLine {
  id             String        @id @default(uuid()) @db.Uuid
