  variantId       String?       @map("variant_id") @db.Uuid
  uomId           String        @map("uom_id") @db.Uuid
  orderedQty      Decimal       @map("ordered_qty") @db.Decimal(18, 4)
  receivedQty     Decimal       @default(0) @map("received_qty") @db.Decimal(18, 4)
  unitCost        Decimal       @map("unit_cost") @db.Decimal(19, 6)
  taxRateId       String?       @map("tax_rate_id") @db.Uuid
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(19, 4)
  lineTotal       Decimal       @map("line_total") @db.Decimal(19, 4)
  expectedDate    DateTime?     @map("expected_date")
  // Spec 005 procurement extensions
  rejectedQty     Decimal       @default(0) @map("rejected_qty") @db.Decimal(18, 4)
  returnedQty     Decimal       @default(0) @map("returned_qty") @db.Decimal(18, 4)
  cancelledQty    Decimal       @default(0) @map("cancelled_qty") @db.Decimal(18, 4)
  discountPct     Decimal?      @map("discount_pct") @db.Decimal(9, 6)
