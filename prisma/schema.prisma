// ============================================================================
// Enterprise CRM — Spec 003 (Phase 4 customer intelligence). CrmCustomerMetrics
// is the per-customer materialized projection (the StockBalance of CRM): folded
// incrementally per domain event by the metrics projection, guarded by the
// monotonic lastEventSequence (an event with id <= lastEventSequence is a
// replay and is skipped). favoritesJson holds the top-N counters the favorite_*
// columns are derived from. Monthly rows provide trend series per periodKey
// (YYYY-MM) without ledger replay. Dashboards read these tables only.
// ============================================================================

model CrmCustomerMetrics {
  id                    String        @id @default(uuid()) @db.Uuid
  tenantId              String        @map("tenant_id") @db.Uuid
  customerId            String        @map("customer_id") @db.Uuid
  firstPurchaseAt       DateTime?     @map("first_purchase_at")
  lastPurchaseAt        DateTime?     @map("last_purchase_at")
  ordersCount           Int           @default(0) @map("orders_count")
  totalSpend            Decimal       @default(0) @map("total_spend") @db.Decimal(19, 4)
  avgOrderValue         Decimal       @default(0) @map("avg_order_value") @db.Decimal(19, 4)
  returnsCount          Int           @default(0) @map("returns_count")
  returnsValue          Decimal       @default(0) @map("returns_value") @db.Decimal(19, 4)
  visitCount            Int           @default(0) @map("visit_count")
  favoriteProductId     String?       @map("favorite_product_id") @db.Uuid
  favoriteCategoryId    String?       @map("favorite_category_id") @db.Uuid
  favoriteWarehouseId   String?       @map("favorite_warehouse_id") @db.Uuid
  favoritePaymentMethod String?       @map("favorite_payment_method")
  favoritesJson         Json?         @map("favorites_json")
  rfmRecency            Int?          @map("rfm_recency")
  rfmFrequency          Int?          @map("rfm_frequency")
  rfmMonetary           Int?          @map("rfm_monetary")
  rfmSegment            String?       @map("rfm_segment")
  churnScore            Decimal?      @map("churn_score") @db.Decimal(9, 6)
  clvEstimate           Decimal?      @map("clv_estimate") @db.Decimal(19, 4)
  lastEventSequence     BigInt        @default(0) @map("last_event_sequence")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  tenant                TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, customerId], map: "crm_customer_metrics_tenant_customer_unique")
  @@index([tenantId, totalSpend(sort: Desc)], map: "crm_customer_metrics_tenant_spend_idx")
  @@index([tenantId, lastPurchaseAt], map: "crm_customer_metrics_tenant_recency_idx")
  @@map("crm_customer_metrics")
}

