// ============================================================================
// Enterprise Inventory — Spec 002 (Phase 6 sales / POS). PosSale complete and
// SalesOrder fulfil POST a SALE (OUT) movement through the engine; each sold line
// snapshots the WAC issue cost (costAtSale) for margin. Purchase orders never
// touched inventory; sales orders reduce it only at fulfilment.
// ============================================================================

enum SalesOrderStatus {
  DRAFT               @map("draft")
  CONFIRMED           @map("confirmed")
  RESERVED            @map("reserved")
  PARTIALLY_FULFILLED @map("partially_fulfilled")
  FULFILLED           @map("fulfilled")
  INVOICED            @map("invoiced")
  CLOSED              @map("closed")
  CANCELLED           @map("cancelled")
  ON_HOLD             @map("on_hold")
  BACKORDERED         @map("backordered")

  @@map("SalesOrderStatus")
}

enum InvoiceStatus {
  DRAFT          @map("draft")
  ISSUED         @map("issued")
  PARTIALLY_PAID @map("partially_paid")
  PAID           @map("paid")
  OVERDUE        @map("overdue")
  CANCELLED      @map("cancelled")

  @@map("InvoiceStatus")
}

enum PosSaleStatus {
  OPEN               @map("open")
  PARKED             @map("parked")
  COMPLETED          @map("completed")
  REFUNDED           @map("refunded")
  PARTIALLY_REFUNDED @map("partially_refunded")
  VOIDED             @map("voided")

  @@map("PosSaleStatus")
}

enum PosSessionStatus {
  OPEN       @map("open")
  CLOSED     @map("closed")
  RECONCILED @map("reconciled")

  @@map("PosSessionStatus")
}

enum PosOrderType {
  COUNTER  @map("counter")
  DINE_IN  @map("dine_in")
  TAKEAWAY @map("takeaway")
  DELIVERY @map("delivery")

  @@map("PosOrderType")
}

enum PaymentMethod {
  CASH          @map("cash")
  CARD          @map("card")
  BANK_TRANSFER @map("bank_transfer")
  WALLET        @map("wallet")
  CREDIT        @map("credit")
  CHEQUE        @map("cheque")

  @@map("PaymentMethod")
}

enum SalesReturnStatus {
  DRAFT      @map("draft")
  REQUESTED  @map("requested")
  APPROVED   @map("approved")
  IN_TRANSIT @map("in_transit")
  RECEIVED   @map("received")
  CREDITED   @map("credited")
  CLOSED     @map("closed")
  REJECTED   @map("rejected")
  CANCELLED  @map("cancelled")

  @@map("SalesReturnStatus")
}

enum SalesReturnReason {
  DAMAGED               @map("damaged")
  DEFECTIVE             @map("defective")
  WRONG_ITEM            @map("wrong_item")
  NOT_AS_DESCRIBED      @map("not_as_described")
  EXPIRED               @map("expired")
  CUSTOMER_CHANGED_MIND @map("customer_changed_mind")
  OTHER                 @map("other")

  @@map("SalesReturnReason")
}

enum NoteType {
  CREDIT @map("credit")
  DEBIT  @map("debit")

  @@map("NoteType")
}

enum NoteStatus {
  DRAFT     @map("draft")
  ISSUED    @map("issued")
  APPLIED   @map("applied")
  CLOSED    @map("closed")
  CANCELLED @map("cancelled")

  @@map("NoteStatus")
}

enum ReservationStatus {
  ACTIVE              @map("active")
  PARTIALLY_FULFILLED @map("partially_fulfilled")
  FULFILLED           @map("fulfilled")
  RELEASED            @map("released")
  EXPIRED             @map("expired")

  @@map("ReservationStatus")
}

enum ReservationType {
  SALES_ORDER @map("sales_order")
  TRANSFER    @map("transfer")
  PRODUCTION  @map("production")
  MANUAL      @map("manual")

  @@map("ReservationType")
}

enum LotStatus {
  ACTIVE     @map("active")
  QUARANTINE @map("quarantine")
  EXPIRED    @map("expired")
  RECALLED   @map("recalled")
  DEPLETED   @map("depleted")

  @@map("LotStatus")
}

enum SerialStatus {
  IN_STOCK   @map("in_stock")
  RESERVED   @map("reserved")
  SOLD       @map("sold")
  IN_TRANSIT @map("in_transit")
  RETURNED   @map("returned")
  SCRAPPED   @map("scrapped")
  IN_REPAIR  @map("in_repair")

  @@map("SerialStatus")
}

enum BomStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")

  @@map("BomStatus")
}

enum ProductionOrderStatus {
  DRAFT               @map("draft")
  PLANNED             @map("planned")
  RELEASED            @map("released")
  IN_PROGRESS         @map("in_progress")
  PARTIALLY_COMPLETED @map("partially_completed")
  COMPLETED           @map("completed")
  CLOSED              @map("closed")
  ON_HOLD             @map("on_hold")
  CANCELLED           @map("cancelled")

  @@map("ProductionOrderStatus")
}

// --- Phase 6: sales orders + invoices ---------------------------------------

model SalesOrder {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @map("tenant_id") @db.Uuid
  documentNumber        String           @map("document_number")
  customerId            String?          @map("customer_id") @db.Uuid
  warehouseId           String           @map("warehouse_id") @db.Uuid
  status                SalesOrderStatus @default(DRAFT)
  orderDate             DateTime         @default(now()) @map("order_date")
  requestedDeliveryDate DateTime?        @map("requested_delivery_date")
  currencyCode          String           @default("USD") @map("currency_code")
  subtotal              Decimal          @default(0) @db.Decimal(19, 4)
  discountTotal         Decimal          @default(0) @map("discount_total") @db.Decimal(19, 4)
  taxTotal              Decimal          @default(0) @map("tax_total") @db.Decimal(19, 4)
  grandTotal            Decimal          @default(0) @map("grand_total") @db.Decimal(19, 4)
  notes                 String?
  priceListId           String?          @map("price_list_id") @db.Uuid
  salesRepProfileId     String?          @map("sales_rep_profile_id") @db.Uuid
  createdByProfileId    String?          @map("created_by_profile_id") @db.Uuid
  correlationId         String?          @map("correlation_id") @db.Uuid
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  tenant                TenantAccount    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lines                 SalesOrderLine[]
  invoices              SalesInvoice[]

  @@unique([tenantId, documentNumber], map: "sales_orders_tenant_number_unique")
  @@index([tenantId, status, orderDate], map: "sales_orders_tenant_status_idx")
  @@index([tenantId, customerId], map: "sales_orders_tenant_customer_idx")
  @@map("sales_orders")
}

model SalesOrderLine {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  salesOrderId String        @map("sales_order_id") @db.Uuid
  lineNo       Int           @map("line_no")
  productId    String        @map("product_id") @db.Uuid
  variantId    String?       @map("variant_id") @db.Uuid
  locationId   String        @map("location_id") @db.Uuid
  uomId        String        @map("uom_id") @db.Uuid
  orderedQty   Decimal       @map("ordered_qty") @db.Decimal(18, 4)
  reservedQty  Decimal       @default(0) @map("reserved_qty") @db.Decimal(18, 4)
  fulfilledQty Decimal       @default(0) @map("fulfilled_qty") @db.Decimal(18, 4)
  invoicedQty  Decimal       @default(0) @map("invoiced_qty") @db.Decimal(18, 4)
  unitPrice    Decimal       @map("unit_price") @db.Decimal(19, 4)
  discount     Decimal       @default(0) @db.Decimal(19, 4)
  taxAmount    Decimal       @default(0) @map("tax_amount") @db.Decimal(19, 4)
  lineTotal    Decimal       @map("line_total") @db.Decimal(19, 4)
  costAtSale   Decimal?      @map("cost_at_sale") @db.Decimal(19, 6)
  createdAt    DateTime      @default(now()) @map("created_at")
  tenant       TenantAccount @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId, salesOrderId], map: "sales_order_lines_order_idx")
  @@index([tenantId, productId], map: "sales_order_lines_product_idx")
  @@map("sales_order_lines")
