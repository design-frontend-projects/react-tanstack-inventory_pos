  @@unique([tenantId, documentNumber], map: "purchase_orders_tenant_number_unique")
  @@index([tenantId, status, orderDate], map: "purchase_orders_tenant_status_idx")
  @@index([tenantId, supplierId], map: "purchase_orders_tenant_supplier_idx")
