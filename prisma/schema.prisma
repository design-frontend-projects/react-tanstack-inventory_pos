generator client {
  provider               = "prisma-client"
  output                 = "../src/server/db/generated/prisma"
  engineType             = "client"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  runtime                = "nodejs"
}

datasource db {
  provider = "postgresql"
}

enum AppLocale {
  EN @map("en")
  AR @map("ar")

  @@map("AppLocale")
}

enum ThemeMode {
  LIGHT  @map("light")
  DARK   @map("dark")
  SYSTEM @map("system")

  @@map("ThemeMode")
}

enum TenantAccountStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  ARCHIVED  @map("archived")

  @@map("TenantAccountStatus")
}

enum OwnerSubscriptionStatus {
  TRIALING @map("trialing")
  ACTIVE   @map("active")
  PAST_DUE @map("past_due")
  CANCELED @map("canceled")
  EXPIRED  @map("expired")

  @@map("OwnerSubscriptionStatus")
}

enum OwnerBillingCycle {
  MONTHLY @map("monthly")
  YEARLY  @map("yearly")

  @@map("OwnerBillingCycle")
}

enum ProfileGlobalStatus {
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  DISABLED  @map("disabled")

  @@map("ProfileGlobalStatus")
}

enum TenantUserStatus {
  INVITED   @map("invited")
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")
  DISABLED  @map("disabled")
  REJECTED  @map("rejected")

  @@map("TenantUserStatus")
}

enum InvitationStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  EXPIRED  @map("expired")
  REVOKED  @map("revoked")
  FAILED   @map("failed")

  @@map("InvitationStatus")
}

enum TenantRegistrationStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")

  @@map("TenantRegistrationStatus")
}

enum PermissionKind {
  SCREEN @map("screen")
  MENU   @map("menu")
  ACTION @map("action")
  API    @map("api")
  DATA   @map("data")
  ADMIN  @map("admin")

  @@map("PermissionKind")
}

enum HttpMethod {
  GET    @map("GET")
  POST   @map("POST")
  PUT    @map("PUT")
  PATCH  @map("PATCH")
  DELETE @map("DELETE")
  ANY    @map("ANY")

  @@map("HttpMethod")
}

model Profile {
  id                   String                      @id @default(uuid()) @db.Uuid
  authUserId           String                      @unique @default(dbgenerated("auth.uid()")) @map("auth_user_id") @db.Uuid
  email                String
  firstName            String?                     @map("first_name")
  lastName             String?                     @map("last_name")
  phone                String?
  avatarUrl            String?                     @map("avatar_url")
  profileCompleted     Boolean                     @default(false) @map("profile_completed")
  onboardingCompleted  Boolean                     @default(false) @map("onboarding_completed")
  globalStatus         ProfileGlobalStatus         @default(ACTIVE) @map("global_status")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  tenantMemberships    TenantUser[]
  ownedTenants         TenantAccount[]             @relation("TenantOwnerProfile")
  invitedMemberships   TenantUser[]                @relation("TenantUserInvitedBy")
  assignedRoles        TenantUserRole[]            @relation("TenantUserRoleAssignedBy")
  assignedPermissions  TenantUserPermission[]      @relation("TenantUserPermissionAssignedBy")
  createdInvitations   user_invitations[]          @relation("InvitationInvitedBy")
  auditLogs            AuditLog[]                  @relation("AuditActor")
  preferenceProfile    PreferenceProfile?
  registrationRequests TenantRegistrationRequest[] @relation("RegistrationLinkedProfile")

  @@index([email], map: "profiles_email_idx")
  @@map("profiles")
}

model TenantAccount {
  id                       String                    @id @default(uuid()) @db.Uuid
  name                     String
  slug                     String                    @unique
  activity                 String?
  activityOptionId         String?                   @map("activity_option_id") @db.Uuid
  timezone                 String?
  status                   TenantAccountStatus       @default(ACTIVE)
  ownerProfileId           String?                   @map("owner_profile_id") @db.Uuid
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  ownerProfile             Profile?                  @relation("TenantOwnerProfile", fields: [ownerProfileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  activityOption           OwnerActivityOption?      @relation(fields: [activityOptionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  subscription             OwnerTenantSubscription?
  memberships              TenantUser[]
  roles                    Role[]
  invitations              user_invitations[]
  auditLogs                AuditLog[]
  preferenceProfiles       PreferenceProfile[]       @relation("DefaultTenantPreference")
  modules                  Module[]
  screens                  Screen[]
  screenActions            ScreenAction[]
  permissions              Permission[]
  tenantModules            TenantModule[]
  tenantScreens            TenantScreen[]
  documentSequences        DocumentSequence[]
  brands                   Brand[]
  productCategories        ProductCategory[]
  unitsOfMeasure           UnitOfMeasure[]
  uomConversions           UomConversion[]
  products                 Product[]
  productVariants          ProductVariant[]
  productBarcodes          ProductBarcode[]
  productImages            ProductImage[]
  productSuppliers         ProductSupplier[]
  priceLists               PriceList[]
  productPrices            ProductPrice[]
  bundleComponents         BundleComponent[]
  attributes               Attribute[]
  attributeOptions         AttributeOption[]
  productAttributeValues   ProductAttributeValue[]
  productTags              ProductTag[]
  productTagLinks          ProductTagLink[]
  suppliers                Supplier[]
  customers                Customer[]
  taxRates                 TaxRate[]
  warehouses               Warehouse[]
  warehouseLocations       WarehouseLocation[]
  stockBalances            StockBalance[]
  inventoryMovements       InventoryMovement[]
  costLayers               CostLayer[]
  stockAdjustments         StockAdjustment[]
  stockAdjustmentLines     StockAdjustmentLine[]
  stockTransfers           StockTransfer[]
  stockTransferLines       StockTransferLine[]
  purchaseRequisitions     PurchaseRequisition[]
  purchaseRequisitionLines PurchaseRequisitionLine[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderLines       PurchaseOrderLine[]
  goodsReceipts            GoodsReceipt[]
  goodsReceiptLines        GoodsReceiptLine[]
  purchaseReturns          PurchaseReturn[]
  purchaseReturnLines      PurchaseReturnLine[]
  salesOrders              SalesOrder[]
  salesOrderLines          SalesOrderLine[]
  salesInvoices            SalesInvoice[]
  salesInvoiceLines        SalesInvoiceLine[]
  posSessions              PosSession[]
  posSales                 PosSale[]
  posSaleLines             PosSaleLine[]
  posPayments              PosPayment[]
  salesReturns             SalesReturn[]
  salesReturnLines         SalesReturnLine[]
  financialNotes           FinancialNote[]
  stockReservations        StockReservation[]
  lots                     Lot[]
  serialNumbers            SerialNumber[]
  billsOfMaterials         BillOfMaterials[]
  bomComponents            BomComponent[]
  productionOrders         ProductionOrder[]
  productionMaterials      ProductionMaterial[]
  productionOutputs        ProductionOutput[]
  reorderRules             ReorderRule[]
  stockSnapshots           StockSnapshot[]
  domainEvents             DomainEvent[]
  crmCustomerProfiles      CrmCustomerProfile[]
  crmCustomerContacts      CrmCustomerContact[]
  crmCustomerAddresses     CrmCustomerAddress[]
  crmCustomerRelationships CrmCustomerRelationship[]
  crmCommunicationConsents CrmCommunicationConsent[]
  crmCustomerPreferences   CrmCustomerPreference[]
  crmTags                  CrmTag[]
  crmCustomerTags          CrmCustomerTag[]
  crmCustomerGroups        CrmCustomerGroup[]
  crmCustomerGroupMembers  CrmCustomerGroupMember[]
  crmCustomFieldDefinitions CrmCustomFieldDefinition[]
  crmCustomFieldValues     CrmCustomFieldValue[]
  crmTimelineEntries       CrmTimelineEntry[]
  crmLoyaltySettings       CrmLoyaltySettings[]
  crmLoyaltyTiers          CrmLoyaltyTier[]
  crmLoyaltyAccounts       CrmLoyaltyAccount[]
  crmLoyaltyLedgerEntries  CrmLoyaltyLedgerEntry[]
  crmLoyaltyEarnRules      CrmLoyaltyEarnRule[]
  crmCustomerMetrics       CrmCustomerMetrics[]
  crmCustomerMetricsMonthly CrmCustomerMetricsMonthly[]
  crmSegments              CrmSegment[]
  crmSegmentMembers        CrmSegmentMember[]
  crmCustomerScores        CrmCustomerScore[]
  resRestaurants           ResRestaurant[]
  resBranches              ResBranch[]
  resBranchMembers         ResBranchMember[]
  resBusinessHours         ResBusinessHours[]
  resHolidays              ResHoliday[]
  resDiningAreas           ResDiningArea[]
  resTableSections         ResTableSection[]
  resTables                ResTable[]
  resTableQrCodes          ResTableQrCode[]
  resServiceTypes          ResServiceType[]
  resShifts                ResShift[]
  resKitchenStations       ResKitchenStation[]
  resKitchenPrinters       ResKitchenPrinter[]
  resReceiptTemplates      ResReceiptTemplate[]
  resTaxConfigs            ResTaxConfig[]
  resServiceChargeRules    ResServiceChargeRule[]
  resDeliverySettings      ResDeliverySettings[]
  resTakeawaySettings      ResTakeawaySettings[]
  resNumberSequences       ResNumberSequence[]
  resRestaurantSettings    ResRestaurantSettings[]
  resBranchSettings        ResBranchSettings[]
  resMenus                 ResMenu[]
  resMenuCategories        ResMenuCategory[]
  resMenuItems             ResMenuItem[]
  resMenuItemVariants      ResMenuItemVariant[]
  resMenuItemPrices        ResMenuItemPrice[]
  resModifierGroups        ResModifierGroup[]
  resModifiers             ResModifier[]
  resMenuItemModifierGroups ResMenuItemModifierGroup[]
  resCombos                ResCombo[]
  resComboComponents       ResComboComponent[]
  resMenuItemAllergens     ResMenuItemAllergen[]
  resMenuItemTags          ResMenuItemTag[]
  resMenuAvailability      ResMenuAvailability[]
  resCrossSells            ResCrossSell[]
  resRecipes               ResRecipe[]
  resRecipeVersions        ResRecipeVersion[]
  resRecipeLines           ResRecipeLine[]
  resRecipeSubRecipes      ResRecipeSubRecipe[]
  resRecipeSteps           ResRecipeStep[]
  resRecipeApprovals       ResRecipeApproval[]
  resOrders                ResOrder[]
  resOrderItems            ResOrderItem[]
  resOrderItemModifiers    ResOrderItemModifier[]
  resOrderPayments         ResOrderPayment[]
  resOrderDiscounts        ResOrderDiscount[]
  resOrderCharges          ResOrderCharge[]
  resOrderSplits           ResOrderSplit[]
  resOrderTransfers        ResOrderTransfer[]
  resOrderEvents           ResOrderEvent[]
  resVoidReasons           ResVoidReason[]
  resCancelReasons         ResCancelReason[]
  podDocumentStatuses      PodDocumentStatus[]
  podStatusTransitions     PodStatusTransition[]
  podSupplierCategories    PodSupplierCategory[]
  podReturnReasons         PodReturnReason[]
  podPaymentMethods        PodPaymentMethod[]
  podLandedCostTypes       PodLandedCostType[]
  podIncoterms             PodIncoterm[]
  podDebitNoteReasons      PodDebitNoteReason[]
  podSupplierContacts      PodSupplierContact[]
  podSupplierAddresses     PodSupplierAddress[]
  podSupplierBankAccounts  PodSupplierBankAccount[]
  podRfqs                  PodRfq[]
  podRfqItems              PodRfqItem[]
  podRfqSuppliers          PodRfqSupplier[]
  podSupplierQuotations    PodSupplierQuotation[]
  podSupplierQuotationItems PodSupplierQuotationItem[]
  podApprovalWorkflows     PodApprovalWorkflow[]
  podApprovalWorkflowSteps PodApprovalWorkflowStep[]
  podApprovalRequests      PodApprovalRequest[]
  podApprovalActions       PodApprovalAction[]
  podSupplierInvoices      PodSupplierInvoice[]
  podSupplierInvoiceItems  PodSupplierInvoiceItem[]
  podSupplierInvoiceMatches PodSupplierInvoiceMatch[]
  podDebitNoteLines        PodDebitNoteLine[]
  podLandedCostVouchers    PodLandedCostVoucher[]
  podLandedCostCharges     PodLandedCostCharge[]
  podLandedCostAllocations PodLandedCostAllocation[]
  podSupplierPayments      PodSupplierPayment[]
  podSupplierPaymentAllocations PodSupplierPaymentAllocation[]
  podAttachments           PodAttachment[]
